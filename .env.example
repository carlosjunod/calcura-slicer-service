# .env.example
# Copy to .env for local dev. Set these in Railway dashboard for production.

# Redis connection (Railway provides this automatically if you add Redis plugin)
REDIS_URL=redis://localhost:6379

# Optional API key for the REST API (recommended for production)
SLICER_API_KEY=your-secret-key-here

# Directory where uploaded files are temporarily stored
UPLOAD_DIR=/tmp/slicer-uploads

# Directory containing OrcaSlicer printer/filament profile JSONs
PROFILES_DIR=/app/profiles

# How many slice jobs to process in parallel per worker instance
# Keep at 1-2 on Railway Starter (2 vCPU), up to 4 on Pro
WORKER_CONCURRENCY=2

# Timeout per slice job in milliseconds (default 5 minutes)
SLICE_TIMEOUT_MS=300000

# Port for the REST API
PORT=3000
